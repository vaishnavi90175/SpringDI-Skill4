<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="student" class="com.example.model.Student">

        <!-- Constructor Injection -->
        <constructor-arg index="0" value="101"/>
        <constructor-arg index="1" value="Vaishnavi"/>
        <constructor-arg index="2" value="CS&amp;IT"/>
        <constructor-arg index="3" value="3"/>

        <!-- Setter Injection -->
        <property name="course" value="CS&amp;IT"/>
        <property name="year" value="4"/>

    </bean>

</beans>